-- BLOODLUST logic with smooth damage bar drain
local function startBloodlust(player, state)
    local status = player:WaitForChild("Status")
    local invListener

    -- Ensure Invulnerable folder exists
    local function ensureInvulnerable()
        if not status:FindFirstChild("Invulnerable") then
            local invFolder = Instance.new("Folder")
            invFolder.Name = "Invulnerable"
            invFolder.Parent = status
        end
    end

    ensureInvulnerable()

    -- Keep Invulnerable folder alive while BLOODLUST is active
    invListener = status.ChildRemoved:Connect(function(child)
        if child.Name == "Invulnerable" then
            ensureInvulnerable()
        end
    end)

    -- Show BLOODLUST popup
    task.spawn(showPopup, player, "BLOODLUST", BLOODLUST_ACTIVATE_SOUND_ID)

    -- After 40 seconds, end BLOODLUST
    task.delay(40, function()
        -- Disconnect invulnerability listener
        if invListener then
            invListener:Disconnect()
        end

        -- Remove Invulnerable folder
        local invFolder = status:FindFirstChild("Invulnerable")
        if invFolder then invFolder:Destroy() end

        -- Smoothly drain the damage bar
        local startValue = state.damageProgress
        local bar = state.damageBar
        local playerState = state

        task.spawn(function()
            local duration = 1 -- drain duration in seconds
            local startTime = os.clock()

            while os.clock() - startTime < duration do
                if not playerStates[player] then break end
                local alpha = (os.clock() - startTime) / duration
                local value = startValue * (1 - alpha)

                playerState.damageProgress = value
                if bar then
                    bar.Size = UDim2.new(1, 0, value / 40000, 0)
                end

                RunService.RenderStepped:Wait()
            end

            -- Ensure bar is fully reset
            if playerStates[player] then
                playerState.damageProgress = 0
                if bar then
                    bar.Size = UDim2.new(1, 0, 0, 0)
                end
            end
        end)
    end)
end

-- BLOODLUST activation
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end

        if input.KeyCode == Enum.KeyCode.C and state.damageProgress >= 40000 then
            local character = player.Character
            if character and not status:FindFirstChild("Invulnerable") then
                startBloodlust(player, state)
            end
        end
    end)

    -- Monitor Kills
    killsValue:GetPropertyChangedSignal("Value"):Connect(function()
        if not playerStates[player] then return end
        local newKills = killsValue.Value
        local gained = newKills - state.lastKills
        if gained > 0 then
            processKills(player, state, gained)
        end
        state.lastKills = newKills
    end)

    player.CharacterAdded:Connect(function(character)
        hookCharacterAndInvulnerable(player, state, character)
    end)

    if player.Character then
        hookCharacterAndInvulnerable(player, state, player.Character)
    end
end

Players.PlayerAdded:Connect(setupPlayer)
Players.PlayerRemoving:Connect(function(player)
	if playerStates[player] and playerStates[player].healthConnection then
		playerStates[player].healthConnection:Disconnect()
	end
	playerStates[player] = nil
end)

for _, player in ipairs(Players:GetPlayers()) do task.spawn(setupPlayer, player) end
