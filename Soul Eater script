local HttpService = game:GetService("HttpService")

-- Configuration
local WEBHOOK_URL = "https://discord.com/api/webhooks/your_webhook_id/your_webhook_token" -- Replace with your Discord webhook URL

-- Function to get player info
local function getPlayerInfo()
    local player = game.Players.LocalPlayer
    if player then
        return {
            Username = player.Name,
            UserId = player.UserId
        }
    else
        return {
            Username = "Unknown",
            UserId = "Unknown"
        }
    end
end

-- Function to send feedback to webhook
local function sendExecutionFeedback()
    local playerInfo = getPlayerInfo()
    local data = {
        username = "Execution Logger",
        embeds = {{
            title = "Script Executed",
            description = string.format("**User:** %s\n**UserId:** %d\n**Time:** %s", playerInfo.Username, playerInfo.UserId, os.date("%Y-%m-%d %H:%M:%S")),
            color = 65280
        }}
    }
    local jsonData = HttpService:JSONEncode(data)

    local success, err = pcall(function()
        HttpService:PostAsync(WEBHOOK_URL, jsonData, Enum.HttpContentType.ApplicationJson)
    end)

    if not success then
        warn("Failed to send execution feedback: " .. tostring(err))
    end
end

-- Send feedback when script runs
sendExecutionFeedback()
